# Git ignore patterns for StadiumBuddy

# Dependencies
node_modules/
.npm-cache/

# Next.js
.next/
out/
build/

# Environment (CRITICAL – never commit secrets)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Coverage reports
coverage/
.nyc_output/

# IDE
.vscode/settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Playwright
playwright-report/
test-results/

# Debug logs
npm-debug.log*

# TypeScript
*.tsbuildinfo
